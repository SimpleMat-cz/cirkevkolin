{
  "version": 2,
  "framework": null,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "rm -f public/hot && npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0",
      "maxDuration": 30,
      "includeFiles": "vendor/laravel/framework/src/Illuminate/Testing/*"
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/build/$1" },
    { "src": "/fonts/(.*)", "dest": "/fonts/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/favicon.ico", "dest": "/favicon.ico" },
    { "src": "/favicon.svg", "dest": "/favicon.svg" },
    { "src": "/apple-touch-icon.png", "dest": "/apple-touch-icon.png" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_STORAGE": "/tmp",
    "VIEW_COMPILED_PATH": "/tmp/views",
    "CACHE_STORE": "array",
    "SESSION_DRIVER": "cookie",
    "QUEUE_CONNECTION": "sync",
    "LOG_CHANNEL": "stderr",
    "SCOUT_DRIVER": "null",
    "COMPOSER_NO_DEV": "1",
    "DB_CONNECTION": "pgsql",
    "DB_SSLMODE": "require",
    "DB_SEARCH_PATH": "cirkev",
    "FILESYSTEM_DISK": "s3",
    "AWS_USE_PATH_STYLE_ENDPOINT": "true"
  },
  "build": {
    "env": {
      "COMPOSER_NO_DEV": "1"
    }
  }
}

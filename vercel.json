{
  "version": 2,
  "framework": null,
  "installCommand": "composer install --no-dev --optimize-autoloader --ignore-platform-reqs && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build && php artisan view:clear && php artisan route:clear && php artisan config:clear",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/build/$1" },
    { "src": "/fonts/(.*)", "dest": "/fonts/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/favicon.ico", "dest": "/favicon.ico" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "env": {
    "APP_STORAGE": "/tmp",
    "VIEW_COMPILED_PATH": "/tmp/views",
    "CACHE_DRIVER": "array",
    "SESSION_DRIVER": "cookie",
    "QUEUE_CONNECTION": "sync",
    "LOG_CHANNEL": "stderr"
  }
}
